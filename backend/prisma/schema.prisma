// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String
  price         Int
  originalPrice Int?
  image         String   // Primary image (first in images array)
  images        String[] @default([])  // All product images (max 6)
  categoryId    String
  inStock       Boolean  @default(true)
  quantity      Int      @default(0)
  badge         String?
  specs         String[] // Array of specs
  variants      Json?    @default("[]") // Array of { type, options, required }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isFeatured    Boolean  @default(false)
  published     Boolean  @default(true)
  salesCount    Int      @default(0)
  deletedAt     DateTime?
  
  category      Category    @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  procurements  Procurement[]
  wholesaleItems WholesaleOrderItem[]
  returnedItems ReturnedItem[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  icon      String?
  image     String?
  active    Boolean   @default(true)
  parentId  String?
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  products  Product[]
}

model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  customerId   String?     // Optional link to persistent customer record
  customerName String
  email        String?     // Optional customer email
  phone        String
  city         String
  address      String
  status       OrderStatus @default(PENDING)
  returnReason String?     // Reason for return
  total        Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  customer     Customer?   @relation(fields: [customerId], references: [id])
  items        OrderItem[]
  returnedItems ReturnedItem[]
}

model Customer {
  id         String   @id @default(uuid())
  name       String
  email      String?  
  phone      String   @unique
  city       String
  address    String
  isFavorite Boolean  @default(false)
  isLoyal    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  orders    Order[]
}

model OrderItem {
  id               String  @id @default(uuid())
  orderId          String
  productId        String
  quantity         Int
  price            Int     // Price at time of purchase
  selectedVariants Json?   // e.g. { "Couleur": "Rouge", "Taille": "M" }

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model ReturnedItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Int      // Price at time of return (for analytics if needed)
  reason    String?
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  RETOUR
}

model City {
  id           String  @id @default(uuid())
  name         String  @unique
  shippingFee  Int
  deliveryTime String
  active       Boolean @default(true)
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[]
  admins      Admin[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("editor")
  roleId    String?
  assignedRole Role?   @relation(fields: [roleId], references: [id])
  active    Boolean  @default(true)
  allowedCategories String[] @default([])
  createdAt DateTime @default(now())

  procurements Procurement[]
  capitalEntries CapitalEntry[]
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  city      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  procurements Procurement[]
}

model Procurement {
  id                String   @id @default(uuid())
  supplierId        String
  productId         String
  quantityPurchased Int
  unitCostPrice     Int
  totalCost         Int      // quantityPurchased * unitCostPrice
  purchaseDate      DateTime @default(now())
  createdByAdminId  String?

  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  admin    Admin?   @relation(fields: [createdByAdminId], references: [id])

  @@index([supplierId])
  @@index([productId])
  @@index([createdByAdminId])
}

model Contact {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model Settings {
  id                String   @id @default(uuid())
  // Store Settings
  storeName         String   @default("MKARIM")
  storeAvailability Boolean  @default(true)
  codEnabled        Boolean  @default(true)
  freeShippingEnabled Boolean @default(false)
  freeShippingThreshold Int   @default(0)
  freeShippingText  String?   @default("Livraison gratuite")
  whatsappNumber    String   @default("+212600000000")
  currency          String   @default("DH")
  logo              String?  @default("/uploads/logo-placeholder.png")
  favicon           String?  @default("/favicon.svg")

  
  // Contact Information
  contactAddress    String   @default("Casablanca, Maroc")
  contactPhone      String   @default("+212600000000")
  contactEmail      String   @default("contact@mkarim.ma")
  contactHours      String   @default("Lun - Sam: 9h - 19h")
  
  // Footer Content
  footerDescription String   @default("Votre destination pour les meilleurs PC et accessoires gaming au Maroc. Qualité garantie, livraison rapide.")
  footerCopyright   String   @default("© 2024 MKARIM. Tous droits réservés.")
  
  // Social Media Links
  facebookLink      String?
  instagramLink     String?
  twitterLink       String?
  youtubeLink       String?
  tiktokLink        String?
  
  // Home Page Content
  categoriesTitle     String   @default("NOS CATÉGORIES")
  categoriesSubtitle  String   @default("Découvrez notre large gamme de produits par univers.")
  categoriesAutoPlayInterval Int @default(3000)
  
  featuredTitle       String   @default("PRODUITS POPULAIRES")
  featuredSubtitle    String   @default("Les meilleures ventes et nouveautés sélectionnées pour vous.")
  whyTitle            String   @default("L'EXCELLENCE MKARIM SOLUTION")
  whySubtitle         String   @default("Nous redéfinissons le standard du gaming au Maroc avec un service irréprochable.")
  whyFeatures         Json     @default("[{\"icon\":\"CreditCard\",\"title\":\"Paiement à la Livraison\",\"description\":\"Payez en cash à la réception de votre commande. Simple et sécurisé.\"},{\"icon\":\"Truck\",\"title\":\"Livraison Rapide\",\"description\":\"Livraison partout au Maroc en 24-72h selon votre ville.\"},{\"icon\":\"ShieldCheck\",\"title\":\"Garantie Produits\",\"description\":\"Tous nos produits sont couverts par une garantie officielle.\"},{\"icon\":\"Award\",\"title\":\"Qualité Premium\",\"description\":\"Nous sélectionnons uniquement des produits de qualité supérieure.\"},{\"icon\":\"Headphones\",\"title\":\"Support Client\",\"description\":\"Notre équipe est disponible pour vous accompagner avant et après achat.\"},{\"icon\":\"Clock\",\"title\":\"Réponse Rapide\",\"description\":\"Confirmation de commande sous 24h et suivi personnalisé.\"}]")
  cartShippingText    String   @default("Logistique incluse")
  
  // CTA Section
  ctaTitle             String   @default("PRÊT À RÉVOLUTIONNER VOTRE SETUP ?")
  ctaSubtitle          String   @default("Rejoignez l'élite des gamers marocains. Qualité certifiée, livraison express et service client dédié.")
  ctaPrimaryBtnText    String   @default("Accéder à la Boutique")
  ctaPrimaryBtnLink    String   @default("/products")
  ctaSecondaryBtnText  String   @default("Besoin d'aide ?")
  ctaSecondaryBtnLink  String   @default("/contact")
  
  // About Page Content
  aboutTitle        String   @default("À Propos de MKARIM")
  aboutDescription  String   @default("MKARIM est votre partenaire de confiance pour tous vos besoins en matériel informatique et gaming au Maroc.")
  aboutMission      String   @default("Notre mission est de fournir des produits de haute qualité à des prix compétitifs avec un service client exceptionnel.")
  aboutMissionDetails String @default("Avec le paiement à la livraison, nous facilitons l'accès à la technologie pour tous, partout au Maroc. Notre équipe passionnée est là pour vous conseiller et vous accompagner dans vos choix.")
  aboutImage        String   @default("https://images.unsplash.com/photo-1593640408182-31c70c8268f5?w=1200")
  aboutValues       Json     @default("[{\"title\":\"Confiance\",\"description\":\"Nous construisons des relations durables basées sur la transparence et l'honnêteté.\"},{\"title\":\"Qualité\",\"description\":\"Chaque produit est soigneusement sélectionné pour garantir des performances optimales.\"},{\"title\":\"Service Client\",\"description\":\"Notre équipe est dédiée à votre satisfaction, avant et après l'achat.\"},{\"title\":\"Fiabilité\",\"description\":\"Livraison rapide et sécurisée partout au Maroc.\"}]")
  aboutHeroImage    String   @default("https://images.unsplash.com/photo-1542751371-adc38448a05e?w=1600&q=80")
  aboutHeroOverlayOpacity Int    @default(90) // 0-100
  aboutHeroBlur           Int    @default(0)   // 0-20
  
  homeHeroOverlayOpacity  Int    @default(80) // 0-100
  homeHeroBlur            Int    @default(0)   // 0-20
  homeHeroAutoPlayInterval Int   @default(5000)
  
  aboutMissionTitle     String   @default("Notre Mission")
  aboutStatsLabel       String   @default("Clients Satisfaits")
  aboutValuesTitle      String   @default("Nos Valeurs")
  productsPageTitle     String   @default("Catalogue Produits")
  productsPageSubtitle  String   @default("MKARIM")
  filterBudgetTitle     String   @default("Budget")
  filterSortTitle       String   @default("Tri")
  filterCategoryTitle   String   @default("Catégorie")
  cartSummaryTitle      String   @default("Résumé de la Commande")
  cartSubtotalText      String   @default("Sous-total")
  
  // Low Stock Settings
  lowStockThreshold Int      @default(5)

  // Invoice Configuration
  invoiceFooterText      String    @default("Merci de votre confiance.")
  invoiceShowTax         Boolean   @default(false)
  invoiceTaxRate         Float     @default(20.0)
  invoiceNotes           String?   @default("Facture générée informatiquement.")
  invoiceSubtitle        String    @default("Vente de PC & Matériel Gaming")
  invoiceAddress         String    @default("Maroc")
  invoiceCustomerHeader String    @default("Facture pour :")

  // Email Configuration (SMTP)
  emailSenderName    String    @default("MKARIM Store")
  emailGmailUser     String    @default("")
  emailAppPassword   String    @default("")
  emailAdminReceiver String    @default("")
  emailEnabled       Boolean   @default(false)

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model HeroSlide {
  id          String   @id @default(uuid())
  image       String
  title       String
  subtitle    String?
  description String?
  buttonText  String   @default("Commander Maintenant")
  buttonLink  String   @default("/products")
  badge       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CapitalEntry {
  id          String   @id @default(uuid())
  amount      Int      // Positive for injection, negative for withdrawal
  type        String   // 'INJECTION', 'WITHDRAWAL', 'PROCUREMENT', 'REVENUE'
  description String?
  date        DateTime @default(now())
  adminId     String?
  admin       Admin?   @relation(fields: [adminId], references: [id])

  @@index([adminId])
}

enum WholesalerType {
  PARTICULIER
  ENTREPRISE
}

model Wholesaler {
  id              String         @id @default(uuid())
  type            WholesalerType @default(PARTICULIER)
  name            String         // Compte as "Nom complet" for Particulier or "Nom entreprise" for Entreprise
  ice             String?        // 15 digits, required for Entreprise
  responsibleName String?        // For Entreprise
  address         String
  phone           String         @unique
  email           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  orders    WholesaleOrder[]
}

model WholesaleOrder {
  id             String            @id @default(uuid())
  wholesalerId   String
  orderNumber    String            @unique
  totalAmount    Int
  advanceAmount  Int               @default(0)
  status         WholesaleStatus   @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  
  wholesaler     Wholesaler        @relation(fields: [wholesalerId], references: [id])
  items          WholesaleOrderItem[]
  payments       WholesalePayment[]
}

model WholesalePayment {
  id               String         @id @default(uuid())
  wholesaleOrderId String
  amount           Int
  date             DateTime       @default(now())
  note             String?
  
  order            WholesaleOrder @relation(fields: [wholesaleOrderId], references: [id], onDelete: Cascade)
}

model WholesaleOrderItem {
  id               String         @id @default(uuid())
  wholesaleOrderId String
  productId        String
  quantity         Int
  unitPrice        Int
  
  order            WholesaleOrder @relation(fields: [wholesaleOrderId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
}

enum WholesaleStatus {
  PENDING
  PAID
}
