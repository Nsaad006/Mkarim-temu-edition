# Database Configuration
# For Docker production: Use 'db' as the host
DATABASE_URL="postgresql://postgres:password@db:5432/mkarim_db?sslmode=disable"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mkarim_db

# Frontend Configuration
# For Docker local testing:
VITE_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# Production URLs (Update these with your domain for VPS)
# VITE_API_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
